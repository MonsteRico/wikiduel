{
  "name": "wikiduel-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run --reporter=verbose",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.6.2",
    "parse5": "^8.0.1",
    "wikipedia": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.0"
  }
}
