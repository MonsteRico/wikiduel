{
  "name": "wikiduel",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "wikiduel-client",
    "wikiduel-server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev --workspace=wikiduel-client\" \"npm run dev --workspace=wikiduel-server\"",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "test": "vitest run --reporter=verbose",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.0",
    "concurrently": "^9.2.1",
    "jsdom": "^28.1.0",
    "vitest": "^4.1.0"
  }
}
